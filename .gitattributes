# Force consistent line endings across platforms
* text=auto
*.py text eol=lf
*.md text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.sh text eol=lf
*.txt text eol=lf

# Binary files — no conversion
*.gz binary
*.bin binary
*.gguf binary
*.safetensors binary
*.onnx binary
*.png binary
*.jpg binary
*.jpeg binary
