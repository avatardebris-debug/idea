# Cron Job Configuration for Email Tool
# This file contains cron job examples for automated email processing

# Hourly processing - Check for new emails every hour
0 * * * * cd /path/to/email-tool && email-tool daemon process --batch-size 100

# Daily processing - Full inbox scan at 2 AM
0 2 * * * cd /path/to/email-tool && email-tool daemon process --full-scan

# Weekly processing - Comprehensive archive on Sundays at 3 AM
0 3 * * 0 cd /path/to/email-tool && email-tool daemon archive --retention 90

# Monthly processing - Monthly report generation on the 1st at 4 AM
0 4 1 * * cd /path/to/email-tool && email-tool dashboard generate-report

# Every 15 minutes - Quick check for urgent emails
*/15 * * * * cd /path/to/email-tool && email-tool daemon process --priority high

# Every 30 minutes - Process attachments
*/30 * * * * cd /path/to/email-tool && email-tool daemon process --attachments-only

# Daily backup - Backup email data daily at 5 AM
0 5 * * * cd /path/to/email-tool && email-tool daemon backup

# Weekly cleanup - Clean up old processed emails weekly on Saturday at 6 AM
0 6 * * 6 cd /path/to/email-tool && email-tool daemon cleanup --older-than 30

# Monthly maintenance - Full system maintenance on the last day of each month
0 7 L * * cd /path/to/email-tool && email-tool daemon maintenance

# Real-time monitoring - Check for new emails every 5 minutes
*/5 * * * * cd /path/to/email-tool && email-tool daemon monitor

# Hourly notification summary - Send summary of processed emails hourly
0 * * * * cd /path/to/email-tool && email-tool daemon notify --summary

# Daily digest - Send daily email digest at 8 AM
0 8 * * * cd /path/to/email-tool && email-tool daemon digest

# Weekly digest - Send weekly email digest every Monday at 9 AM
0 9 * * 1 cd /path/to/email-tool && email-tool daemon digest --weekly

# Monthly digest - Send monthly email digest on the 1st at 10 AM
0 10 1 * * cd /path/to/email-tool && email-tool daemon digest --monthly

# Health check - Check system health every 10 minutes
*/10 * * * * cd /path/to/email-tool && email-tool daemon health-check

# Log rotation - Rotate logs weekly on Sunday at midnight
0 0 * * 0 cd /path/to/email-tool && email-tool daemon rotate-logs

# Database cleanup - Clean up old database entries monthly on the 15th at 11 AM
0 11 15 * * cd /path/to/email-tool && email-tool daemon db-cleanup

# SSL certificate check - Check SSL certificates monthly on the 1st at 12 PM
0 12 1 * * cd /path/to/email-tool && email-tool daemon ssl-check

# Performance monitoring - Collect performance metrics every 5 minutes
*/5 * * * * cd /path/to/email-tool && email-tool daemon metrics

# Security scan - Run security scan weekly on Sunday at 1 AM
0 1 * * 0 cd /path/to/email-tool && email-tool daemon security-scan

# Compliance check - Run compliance check monthly on the 15th at 2 PM
0 14 15 * * cd /path/to/email-tool && email-tool daemon compliance-check

# Backup verification - Verify backups weekly on Wednesday at 3 PM
0 15 * * 3 cd /path/to/email-tool && email-tool daemon backup-verify

# Data export - Export data monthly on the 1st at 4 PM
0 16 1 * * cd /path/to/email-tool && email-tool daemon export

# Integration sync - Sync with external systems every 30 minutes
*/30 * * * * cd /path/to/email-tool && email-tool daemon sync

# Rule validation - Validate rules daily at 5 PM
0 17 * * * cd /path/to/email-tool && email-tool daemon validate-rules

# Cache cleanup - Clean cache weekly on Saturday at 6 PM
0 18 * * 6 cd /path/to/email-tool && email-tool daemon cache-cleanup

# Temporary file cleanup - Clean temporary files daily at 7 PM
0 19 * * * cd /path/to/email-tool && email-tool daemon temp-cleanup

# Index rebuild - Rebuild search index weekly on Sunday at 8 PM
0 20 * * 0 cd /path/to/email-tool && email-tool daemon rebuild-index

# Full backup - Full system backup monthly on the 1st at 9 PM
0 21 1 * * cd /path/to/email-tool && email-tool daemon full-backup

# System update check - Check for updates weekly on Monday at 10 PM
0 22 * * 1 cd /path/to/email-tool && email-tool daemon check-updates

# License check - Check license status monthly on the 15th at 11 PM
0 23 15 * * cd /path/to/email-tool && email-tool daemon license-check