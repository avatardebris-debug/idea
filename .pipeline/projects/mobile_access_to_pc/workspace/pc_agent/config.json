{
  "server": {
    "host": "0.0.0.0",
    "port": 8765,
    "max_connections": 5,
    "heartbeat_interval": 30,
    "connection_timeout": 300
  },
  "screen": {
    "capture_fps": 15,
    "quality": 75,
    "target_bitrate": 2000,
    "scale_factor": 1.0,
    "monitor": 0,
    "auto_adjust_quality": true
  },
  "security": {
    "enable_tls": false,
    "tls_cert_path": null,
    "tls_key_path": null,
    "require_auth": true,
    "auth_token": null
  },
  "input": {
    "mouse_sensitivity": 1.0,
    "keyboard_delay": 0.05,
    "log_input_events": true
  },
  "logging": {
    "level": "INFO",
    "log_file": "pc_agent.log",
    "max_log_size": 10485760,
    "backup_count": 5
  },
  "device": {
    "device_name": "PC-$(hostname)",
    "device_id": null
  }
}
