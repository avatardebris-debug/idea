{
  "name": "thronglets-vr-practice-mode",
  "version": "1.0.0",
  "description": "VR Practice Mode for Thronglets - A virtual reality simulation environment for monitoring and managing Thronglets",
  "main": "vr_practice.js",
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:verbose": "vitest run --reporter=verbose",
    "test:coverage": "vitest run --coverage",
    "start": "node vr_practice.js",
    "dev": "node vr_practice.js --dev"
  },
  "keywords": [
    "vr",
    "virtual-reality",
    "simulation",
    "thronglets",
    "monitoring",
    "visualization"
  ],
  "author": "Thronglets Team",
  "license": "MIT",
  "dependencies": {},
  "devDependencies": {
    "vitest": "^1.0.0",
    "@vitest/coverage-v8": "^1.0.0"
  },
  "engines": {
    "node": ">=14.0.0"
  }
}
