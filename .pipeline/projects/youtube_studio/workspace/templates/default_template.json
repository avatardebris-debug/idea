{
  "name": "default_video_metadata",
  "description": "Default template for video metadata generation including title, keywords, and thumbnail suggestions",
  "version": "1.0.0",
  "variables": [
    "video_title",
    "video_description",
    "video_category",
    "target_audience",
    "video_length",
    "upload_date",
    "video_tags",
    "thumbnail_style",
    "keywords",
    "main_topic"
  ],
  "tags": ["video", "metadata", "youtube", "default"],
  "content": {
    "title_template": "{{video_title}} - {{main_topic}}",
    "description_template": "{{video_description}}\n\n#{{video_tags}}\n\n#{{keywords}}",
    "thumbnail_text": "{{main_topic}}",
    "keywords_suggestion": "{{keywords}}",
    "thumbnail_style_suggestion": "{{thumbnail_style}}",
    "target_audience": "{{target_audience}}"
  }
}
